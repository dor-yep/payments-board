{
  "name": "payments-board",
  "version": "0.1.0",
  "description": "Monday.com app for amortization payments clearance",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev:server": "tsx watch src/index.ts",
    "dev:expose": "npx @mondaycom/apps-cli tunnel:create -p 3000 -a 11007042",
    "dev": "concurrently -n server,expose -c blue,green \"npm run dev:server\" \"npm run dev:expose\"",
    "deploy": "npm run build && npx @mondaycom/apps-cli code:push -d ./dist -a 11007042",
    "deploy:versions": "npx @mondaycom/apps-cli app-version:list -a 11007042"
  },
  "dependencies": {
    "express": "^4.21.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "@types/express": "^4.17.21",
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
